# ============================================================
# DGCC PES — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Server-side only, never expose to client

# --- DATABASE (Supabase Postgres via Prisma) ---
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# --- AUTH ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# --- APP ---
NEXT_PUBLIC_APP_NAME="DGCC Enterprise System"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- STORAGE (Supabase Storage for attachments) ---
SUPABASE_STORAGE_BUCKET=pes-attachments

# --- EMAIL (optional — for notifications) ---
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM="DGCC System <noreply@yourdomain.com>"

# --- SEED / ADMIN BOOTSTRAP ---
SEED_ADMIN_EMAIL=admin@dgcc.edu.sa
SEED_ADMIN_PASSWORD=change-this-in-production
